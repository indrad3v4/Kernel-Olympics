[0.01, "o", "    \u001b[1;34mcompile         \u001b[0m hipcc device-only proof harness\r\n"]
[0.01, "o", "    \u001b[1;34mrun             \u001b[0m Execute proof on AMD GPU\r\n"]
[0.01, "o", "\r\n"]
[0.01, "o", "  \u001b[1mDemo & recording\u001b[0m\r\n"]
[0.01, "o", "    \u001b[1;34mdemo            \u001b[0m Full migration demo (3-5 min)\r\n"]
[0.01, "o", "    \u001b[1;34mrecord          \u001b[0m asciinema recording\r\n"]
[0.01, "o", "\r\n"]
[0.01, "o", "  \u001b[1mQuality\u001b[0m\r\n"]
[0.01, "o", "    \u001b[1;34mtest            \u001b[0m 665 unit tests\r\n"]
[0.01, "o", "    \u001b[1;34mdoctor          \u001b[0m Pre-flight check\r\n"]
[0.01, "o", "    \u001b[1;34mlint            \u001b[0m Ruff linter\r\n"]
[0.01, "o", "\r\n"]
