[0.01, "o", "\u001b[1mKernel Olympics \u2014 CUDA \u2192 ROCm Migration\u001b[0m\r\n"]
[0.01, "o", "\r\n"]
[0.01, "o", "  \u001b[2mUsage:\u001b[0m    make <target>   [CU_FILE=path/to/kernel.cu]\r\n"]
[0.01, "o", "\r\n"]
[0.01, "o", "  \u001b[1mCore workflow\u001b[0m\r\n"]
[0.01, "o", "    \u001b[1;34mpipeline        \u001b[0m Port \u2192 compile \u2192 run (full cycle)\r\n"]
