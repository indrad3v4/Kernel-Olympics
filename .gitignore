# Build artifacts
ported_kernels/

# `data/*`, not `data/` — git cannot re-include a file whose parent directory is
# excluded, and data/prompt_changelog.json is a tracked deliverable (see
# prompts/CHANGELOG.md). Ignoring the contents instead of the directory lets the
# negation below work.
data/*
!data/prompt_changelog.json

# Dependencies
.venv/
node_modules/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Reports
*.json
!src/verification/specs/*.json
!sample_kernels/reference/*.json
!sample_kernels/reference/*_output.txt
!src/verification/specs/*.json
!data/prompt_changelog.json

# Runs (per-invocation reproducibility logs)
runs/

# Debug Mode sessions (--debug). These hold raw model responses, full prompts and
# the original kernel source — a session directory is a diagnostic artifact for
# the developer who produced it, never a commit. The blanket *.json rule above
# does not cover the .txt/.jsonl/.md/.diff/.cu artifacts a session also writes.
debug/

# Environment
.env
.venv/
venv/

# QA slide images
slides/*.jpg

# IDE
.idea/
.vscode/
*.swp
