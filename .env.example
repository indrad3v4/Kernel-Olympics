# Kernel Olympics — Environment Configuration
# Copy this to .env and fill in your API keys
#KINDLY DO NOT COMMIT THE ACTUAL API KEY. THIS IS A PUBLIC REPO. 
# Fireworks AI API Key (required for LLM-powered porting)
# Get yours at: https://fireworks.ai/
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Optional: Model override (default: accounts/fireworks/models/llama-v3p1-8b-instruct)
# FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct

# AMD Developer Cloud SSH config (for remote GPU verification)
# AMD_SSH_HOST=your-amd-instance-ip
# AMD_SSH_KEY_PATH=~/.ssh/amd_adp_key
