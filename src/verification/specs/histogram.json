{
  "kernel_function": "histogram_kernel",
  "params": [
    {"name": "input", "type": "const float*", "direction": "input"},
    {"name": "histogram", "type": "int*", "direction": "output"},
    {"name": "n", "type": "int", "direction": "scalar"},
    {"name": "num_bins", "type": "int", "direction": "scalar"}
